{
  "name": "claude-smart",
  "version": "0.2.45",
  "description": "Self-improving Claude Code and Codex plugin that turns corrections into Preferences, Project-specific skills, and Shared skills",
  "keywords": [
    "claude",
    "claude-code",
    "claude-code-plugin",
    "codex",
    "codex-plugin",
    "memory",
    "agent-memory",
    "plugin",
    "reflexio",
    "self-improvement",
    "self-improving-agents",
    "skills",
    "learning"
  ],
  "homepage": "https://github.com/ReflexioAI/claude-smart#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ReflexioAI/claude-smart.git"
  },
  "bugs": {
    "url": "https://github.com/ReflexioAI/claude-smart/issues"
  },
  "license": "Apache-2.0",
  "author": "Yi Lu",
  "type": "commonjs",
  "bin": {
    "claude-smart": "bin/claude-smart.js"
  },
  "files": [
    "bin",
    "scripts/setup-claude-smart.sh",
    ".agents/plugins/marketplace.json",
    ".claude-plugin/marketplace.json",
    "plugin",
    "!plugin/**/__pycache__",
    "!plugin/**/*.py[cod]",
    "!plugin/**/.pytest_cache",
    "!plugin/**/.ruff_cache",
    "!plugin/**/.mypy_cache",
    "!plugin/**/.venv",
    "!plugin/**/node_modules",
    "!plugin/**/.next/cache",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.9.0"
